# PostgreSQL (use a pooler URL in production, e.g. PgBouncer / Neon / Prisma Accelerate)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Optional: cap pg Pool max connections per instance (default 10)
PG_POOL_MAX="10"

# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Legacy / optional depending on Clerk version
NEXT_PUBLIC_CLERK_FRONTEND_API="https://YOUR_INSTANCE.clerk.accounts.dev"

# Comma-separated emails that become ADMIN on first DB sync (dashboard + webhooks)
ADMIN_EMAILS="owner@example.com"

# Clerk webhooks — signing secret from Dashboard → Webhooks
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."

# Optional: Upstash Redis for API rate limiting (middleware)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Cloudinary (gallery uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# SMTP (optional notifications)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
MAIL_FROM=""
