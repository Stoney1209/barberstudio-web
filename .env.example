# PostgreSQL (use a pooler URL in production, e.g. PgBouncer / Neon / Prisma Accelerate)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Optional: cap pg Pool max connections per instance (default 10)
PG_POOL_MAX="10"

# Supabase Auth (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Comma-separated emails that become ADMIN on first DB sync (dashboard + webhooks)
ADMIN_EMAILS="owner@example.com"

# Optional: Upstash Redis for API rate limiting (middleware)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Cloudinary (gallery uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# SMTP (optional notifications - implement if needed)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
MAIL_FROM=""
